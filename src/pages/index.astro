---
import CodingSkillsItem from "@/components/CodingSkillsItem.astro";
import EducationItem from "@/components/EducationItem.astro";
import ExperienceItem from "@/components/ExperienceItem.astro";
import AstroIcon from "@/components/icons/AstroIcon.astro";
import CameraIcon from "@/components/icons/CameraIcon.astro";
import ConsoleIcon from "@/components/icons/ConsoleIcon.astro";
import DiscoBallIcon from "@/components/icons/DiscoBallIcon.astro";
import DotNetIcon from "@/components/icons/DotNetIcon.astro";
import EnvelopeIcon from "@/components/icons/EnvelopeIcon.astro";
import LaravelIcon from "@/components/icons/LaravelIcon.astro";
import MapPinIcon from "@/components/icons/MapPinIcon.astro";
import ReactIcon from "@/components/icons/ReactIcon.astro";
import RunningFootIcon from "@/components/icons/RunningFootIcon.astro";
import TailwindIcon from "@/components/icons/TailwindIcon.astro";
import VueIcon from "@/components/icons/VueIcon.astro";
import SkillPill from "@/components/SkillPill.astro";
import GlassSurface from "@/components/GlassSurface.astro";
import Layout from "@/layouts/Layout.astro";
import GitHubIcon from "@/components/icons/GitHubIcon.astro";
import BrazilFlagIcon from "@/components/icons/BrazilFlagIcon.astro";
---

<Layout>
    <main>
        <section class="container max-w-7xl mx-auto">
            <div
                class="px-4 lg:px-24 pt-12 pb-8 grid grid-cols-1 md:grid-cols-2 gap-6"
            >
                <div class="space-y-6">
                    <h1
                        class="text-[5.5rem] leading-[1] font-display text-neutral-50"
                    >
                        Hello,<br /> I'm <small class="text-[6px]">a.k.a.</small
                        >
                        <span class="text-primary-300">Reis</span>
                    </h1>
                    <p class="text-lg text-neutral-300">
                        I'm a software engineer and a web developer. I love to
                        build things for the web and I'm always looking for new
                        challenges.
                    </p>

                    <div
                        class="flex flex-col md:flex-row space-y-2 md:space-y-0 md:space-x-2"
                    >
                        <a
                            class="lg:w-fit flex items-center justify-center text-white px-6 py-3 bg-primary-300/10 border border-primary-300/20 shadow-lg shadow-primary-300/10 hover:ring-2 ring-primary-300 transition-all ease-in-out"
                            href="https://github.com/mateuskonige/"
                            target="_blank"
                        >
                            <GitHubIcon />

                            <p
                                class="text-sm ml-2 lg:text-base text-primary-300"
                            >
                                /<b>mateuskonige</b>
                            </p>
                        </a>
                    </div>
                </div>

                <div class="relative">
                    <img
                        id="rocky-egg"
                        class="w-44 h-44 fixed -left-38 bottom-2 z-40 cursor-pointer md:absolute md:left-auto md:bottom-15 md:right-14 md:-z-10 md:cursor-auto md:pointer-events-none"
                        src="/rocky.png"
                        alt="Amaze amaze amaze!"
                    />
                    <div class="flex justify-center">
                        <div
                            id="picture-card"
                            class="border border-primary-300/30 shadow-primary-300/30 w-full lg:w-96 h-[450px] lg:h-96 bg-[url('/picture.webp')] bg-cover bg-top shadow-2xl relative z-10 isolate"
                            style="background-size: 127%; background-position: top 0% left 42%;"
                        >
                            <span
                                class="absolute text-xs lg:text-base top-[10%] md:top-[6%] -right-2 lg:-right-8 rounded-xl font-medium bg-primary-300/10 border border-primary-300/30 px-2 py-1 shadow-xl"
                            >
                                <BrazilFlagIcon />
                            </span>
                            <div
                                class="bg-neutral-900/50 backdrop-blur-md absolute bottom-0 w-full text-neutral-50 pl-12 py-3"
                            >
                                <span class="font-display text-2xl"
                                    >Contact</span
                                >

                                <div class="text-xs py-1">
                                    <div class="flex items-center space-x-0.5">
                                        <MapPinIcon />
                                        <p>Minas Gerais, Brazil</p>
                                    </div>
                                    <div class="flex items-center space-x-0.5">
                                        <EnvelopeIcon />
                                        <p>
                                            <a
                                                href="mailto:mateuskonige@gmail.com"
                                                >mateuskonige@gmail.com</a
                                            >
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="text-neutral-50">
            <div class="max-w-7xl mx-auto lg:px-24 pt-5 lg:pt-12 pb-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div
                        class="p-4 lg:p-0 relative h-fit mb-8 order-last md:order-first"
                    >
                        <h2 class="text-4xl font-display text-primary-300 pb-8">
                            Education
                        </h2>

                        <div class="space-y-4">
                            <EducationItem
                                date="2019-2023"
                                location="University of Montes Claros"
                                course="Information Systems"
                                isLast={false}
                            />
                            <EducationItem
                                date="2021-2021"
                                location="EspecializaTI"
                                course="Laravel Certification"
                                isLast={false}
                            />
                            <EducationItem
                                date="2013-2015"
                                location="Dilma Quadros"
                                course="High School"
                                isLast={true}
                            />
                        </div>

                        <div
                            class="absolute top-[calc(100%+2rem)] left-0 w-full rounded-lg overflow-hidden py-8 px-4 shadow-lg"
                        >
                            <div class="relative">
                                <h2
                                    class="lg:ml-8 text-4xl font-display text-primary-300 pb-8"
                                >
                                    Experience
                                </h2>

                                <div class="space-y-4 mb-8">
                                    <ExperienceItem
                                        date="2024-2026"
                                        location="COM3 Systems Engineering"
                                        course="IT Business Analyst"
                                        isLast={false}
                                    />
                                    <ExperienceItem
                                        date="2021-2023"
                                        location="State University of Montes Claros"
                                        course="Intern Full Stack Developer"
                                        isLast={true}
                                    />
                                </div>

                                <div>
                                    <div class="flex gap-2 flex-wrap">
                                        <SkillPill text="Front-end" />
                                        <SkillPill text="Back-end" />
                                        <SkillPill text="UI/UX Design" />
                                        <SkillPill text="Problem-solving" />
                                        <SkillPill text="Software Analyst" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 lg:p-0">
                        <div class="relative w-full">
                            <h2
                                class="text-center opacity-50 text-[4rem] lg:text-[5.65rem] xl:text-[7.5rem] leading-[1] font-display uppercase text-transparent bg-clip-text stroke"
                            >
                                Resume
                            </h2>

                            <h2
                                class="absolute opacity-35 right-0 -top-[100%] lg:-top-[95%] xl:-top-[85%] text-[4rem] lg:text-[5.65rem] xl:text-[7.5rem] leading-[1] font-display uppercase text-transparent bg-clip-text stroke"
                            >
                                Resume
                            </h2>
                            <h2
                                class="absolute opacity-35 top-[100%] lg:top-[95%] xl:top-[85%] text-[4rem] lg:text-[5.65rem] xl:text-[7.5rem] leading-[1] font-display uppercase text-transparent bg-clip-text stroke"
                            >
                                Resume
                            </h2>
                        </div>

                        <h2
                            class="mt-9 lg:mt-12 text-3xl font-display text-primary-300 pb-8"
                        >
                            Technical Skills
                        </h2>

                        <div class="pb-8">
                            <div>
                                <p class="font-display text-lg mb-3">
                                    Coding skills
                                </p>
                            </div>

                            <div class="flex gap-2">
                                <CodingSkillsItem name="React">
                                    <ReactIcon />
                                </CodingSkillsItem>
                                <CodingSkillsItem name="Vue.js">
                                    <VueIcon />
                                </CodingSkillsItem>
                                <CodingSkillsItem name="Laravel">
                                    <LaravelIcon />
                                </CodingSkillsItem>
                                <CodingSkillsItem name="Asp.Net">
                                    <DotNetIcon />
                                </CodingSkillsItem>
                                <CodingSkillsItem name="Tailwind">
                                    <TailwindIcon />
                                </CodingSkillsItem>
                                <CodingSkillsItem name="Astro.js">
                                    <AstroIcon />
                                </CodingSkillsItem>
                            </div>
                        </div>

                        <div>
                            <p class="font-display text-lg mb-3">Soft skills</p>
                        </div>
                        <div>
                            <div class="flex gap-2 flex-wrap">
                                <SkillPill text="#Competent" />
                                <SkillPill text="#Resilient" />
                                <SkillPill text="#Dedicated" />
                                <SkillPill text="#Discreet" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="container max-w-7xl mx-auto">
            <div
                class="px-4 lg:px-24 pt-8 lg:pt-12 pb-8 lg:pb-12 grid grid-cols-1 md:grid-cols-2 gap-6"
            >
                <div
                    class="mt-[24rem] min-[380px]:mt-[19.5rem] sm:mt-[17rem] md:mt-[13rem] lg:mt-[12rem] xl:mt-36"
                >
                    <h2 class="text-4xl font-display text-primary-300 pb-8">
                        Activities
                    </h2>

                    <div class="space-y-4">
                        <EducationItem
                            date="2021"
                            location="My first system deployed"
                            course="Dionysus"
                            isLast={false}
                        />
                        <EducationItem
                            date="2020"
                            location="My first UI clone. :)"
                            course="Netflix"
                            isLast={true}
                        />
                    </div>
                </div>

                <div class="">
                    <h2 class="text-4xl font-display text-primary-300 pb-8">
                        Languages
                    </h2>

                    <div class="grid grid-cols-2 pb-8">
                        <div>
                            <p class="font-display text-xl text-white">
                                English
                            </p>
                            <p class="text-sm text-gray-400">Advanced</p>
                        </div>
                        <div>
                            <p class="font-display text-xl text-white">
                                Portuguese
                            </p>
                            <p class="text-sm text-gray-400">Native</p>
                        </div>
                    </div>

                    <h2 class="text-4xl font-display text-primary-300 pb-8">
                        Hobbies & Interests
                    </h2>

                    <div
                        class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4"
                    >
                        <div
                            class="pl-2 md:pl-0 rounded bg-neutral-900/30 border border-primary-300/30 shadow-xl shadow-primary-300/10 text-slate-50 py-2 flex space-x-4 md:space-x-0 md:flex-col items-center"
                        >
                            <div
                                class="size-16 flex items-center justify-center"
                            >
                                <RunningFootIcon />
                            </div>
                            <p class="text-sm lg:pt-1 mb-1">Running/Gym</p>
                        </div>
                        <div
                            class="pl-2 md:pl-0 bg-neutral-900/30 border border-primary-300/30 shadow-xl shadow-primary-300/10 text-slate-50 py-2 flex space-x-4 md:space-x-0 md:flex-col items-center"
                        >
                            <div
                                class="size-16 flex items-center justify-center"
                            >
                                <CameraIcon />
                            </div>
                            <p class="text-sm lg:pt-1 mb-1">Photography</p>
                        </div>
                        <div
                            class="pl-2 md:pl-0 bg-neutral-900/30 border border-primary-300/30 shadow-xl shadow-primary-300/10 text-slate-50 py-2 flex space-x-4 md:space-x-0 md:flex-col items-center"
                        >
                            <div
                                class="size-16 flex items-center justify-center"
                            >
                                <ConsoleIcon />
                            </div>
                            <p class="text-sm lg:pt-1 mb-1">Play games</p>
                        </div>
                        <div
                            class="pl-2 md:pl-0 bg-neutral-900/30 border border-primary-300/30 shadow-xl shadow-primary-300/10 text-slate-50 py-2 flex space-x-4 md:space-x-0 md:flex-col items-center"
                        >
                            <div
                                class="size-16 flex items-center justify-center"
                            >
                                <DiscoBallIcon />
                            </div>
                            <p class="text-sm lg:pt-1 mb-1">DJing</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        const card = document.getElementById("picture-card");
        const rocky = document.getElementById("rocky-egg");
        const mql = window.matchMedia("(min-width: 768px)");

        if (rocky) {
            const desktopPhases = [
                { duration: 500, stay: 2000 },
                { duration: 3000, stay: 2000 },
                { duration: 100, stay: 300 },
            ];
            const mobilePhases = [
                { duration: 600, stay: 2000 },
                { duration: 2500, stay: 2000 },
            ];
            let clicks = 0;
            let desktopPhase = 0;
            let mobilePhase = 0;
            let busy = false;

            const play = (cfg, keyframes) => {
                if (busy) return;
                busy = true;

                const total = cfg.duration * 2 + cfg.stay;
                const inEnd = cfg.duration / total;
                const stayMid = (cfg.duration + cfg.stay / 2) / total;
                const stayEnd = (cfg.duration + cfg.stay) / total;

                const animation = rocky.animate(
                    keyframes(inEnd, stayMid, stayEnd),
                    { duration: total, easing: "ease-out" },
                );
                animation.onfinish = () => {
                    busy = false;
                };
            };

            const desktopKeyframes = (inEnd, stayMid, stayEnd) => [
                { transform: "translateX(0) rotate(0deg)", offset: 0 },
                { transform: "translateX(80%) rotate(15deg)", offset: inEnd },
                {
                    transform: "translateX(80%) rotate(-10deg)",
                    offset: stayMid,
                },
                { transform: "translateX(80%) rotate(15deg)", offset: stayEnd },
                { transform: "translateX(0) rotate(0deg)", offset: 1 },
            ];

            const mobileKeyframes = (inEnd, stayMid, stayEnd) => [
                { transform: "translateX(0) rotate(0deg)", offset: 0 },
                { transform: "translateX(8rem) rotate(-15deg)", offset: inEnd },
                {
                    transform: "translateX(8rem) rotate(10deg)",
                    offset: stayMid,
                },
                {
                    transform: "translateX(8rem) rotate(-15deg)",
                    offset: stayEnd,
                },
                { transform: "translateX(0) rotate(0deg)", offset: 1 },
            ];

            if (card) {
                card.addEventListener("click", () => {
                    if (!mql.matches) return;
                    if (busy) return;
                    clicks++;
                    if (clicks < 5) return;
                    clicks = 0;
                    const cfg = desktopPhases[desktopPhase];
                    desktopPhase = (desktopPhase + 1) % desktopPhases.length;
                    play(cfg, desktopKeyframes);
                });
            }

            rocky.addEventListener("click", () => {
                if (mql.matches) return;
                const cfg = mobilePhases[mobilePhase];
                mobilePhase = (mobilePhase + 1) % mobilePhases.length;
                play(cfg, mobileKeyframes);
            });
        }
    </script>
</Layout>
