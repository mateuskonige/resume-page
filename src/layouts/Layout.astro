---
import BoltIcon from "@/components/icons/BoltIcon.astro";
import Galaxy from "@/components/Galaxy.astro";
import GlassSurface from "@/components/GlassSurface.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>Mateus Reis | Full Stack Dev</title>

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.bunny.net" />
        <link
            href="https://fonts.bunny.net/css?family=Ubuntu:400,500,600&display=swap"
            rel="stylesheet"
        />
        <link rel="preconnect" href="https://fonts.bunny.net" />
        <link
            href="https://fonts.bunny.net/css?family=Aclonica:400,500,600&display=swap"
            rel="stylesheet"
        />
    </head>

    <body class="font-sans bg-neutral-950">
        <Galaxy
            density={5}
            hueShift={100}
            glowIntensity={0.1}
            speed={0.1}
            rotationSpeed={0.1}
            mouseRepulsion={false}
            class="fixed inset-0 z-0 pointer-events-none"
        />
        <div class="relative z-10">
            <nav class="sticky top-2 z-50 p-4 lg:p-6 max-w-6xl mx-auto">
                <GlassSurface
                    glow={0.1}
                    borderRadius={35}
                    borderWidth={0.07}
                    brightness={75}
                    opacity={1}
                    blur={7}
                    displace={2}
                    backgroundOpacity={0.1}
                    saturation={0.5}
                    distortionScale={-50}
                />
                <div
                    class="container flex items-center justify-between relative"
                >
                    <a href="/" class="flex items-center">
                        <BoltIcon fill="fill-primary-300" />

                        <span
                            class="font-bold text-2xl font-display text-neutral-50"
                            >Mateus Reis</span
                        >
                    </a>
                    <div class="hidden sm:block space-x-3">
                        <a
                            href="/about"
                            class="rounded-full font-medium border border-neutral-800 text-neutral-50 px-3 py-2 hover:ring-2 ring-primary-300 transition-all ease-in-out"
                            >Work</a
                        >

                        <a
                            href="https://www.linkedin.com/in/mateuskonige/"
                            target="_blank"
                            class="rounded-full font-medium bg-primary-300 px-3 py-2 hover:ring-2 ring-secondary-900 transition-all ease-in-out"
                            >Get in touch!</a
                        >
                        <!-- botoes -->
                    </div>
                    <div class="sm:hidden">
                        <a
                            href="https://www.linkedin.com/in/mateuskonige/"
                            target="_blank"
                            class="text-xs font-display lg:text-base rounded-full font-medium bg-primary-300 px-3 py-2"
                            >!</a
                        >
                    </div>
                </div>
            </nav>

            <slot />

            <footer class="relative p-6 text-slate-50">
                <div
                    class="container max-w-7xl mx-auto flex items-center justify-between relative"
                >
                    <div class="flex items-center">
                        <BoltIcon fill="fill-primary-300" />
                    </div>
                    <div>
                        <p class="text-right">
                            Made with ❤️ by <span class="font-display"
                                >Mateus Reis</span
                            >
                        </p>
                        <p class="text-[9px] text-right text-neutral-500">
                            Design by <span class="font-display">Hannnb</span>
                        </p>
                    </div>
                </div>
            </footer>
        </div>

        <script>
            import Lenis from "lenis";

            const lenis = new Lenis({
                duration: 1,
                easing: (t) => 1 - Math.pow(1 - t, 3),
                smoothWheel: true,
            });

            function raf(time: number) {
                lenis.raf(time);
                requestAnimationFrame(raf);
            }

            requestAnimationFrame(raf);
        </script>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
