---
interface Props {
    name: string;
}

const { name } = Astro.props;
---

<div
    class="flex items-center w-10 overflow-x-hidden relative hover:w-32 transition-all ease-in-out bg-neutral-400/10 border border-neutral-800 p-2 rounded"
>
    <slot />
    <span class="cursor-default absolute left-12 font-medium text-neutral-50"
        >{name}</span
    >
</div>
